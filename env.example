import React, { useState } from 'react';
import { Dumbbell, Zap, Flame, Sparkles, ChevronRight, X } from 'lucide-react';
import { SERVICES, GYM_CONTACT } from '../data';

const iconMap: Record<string, React.ComponentType<{ className?: string }>> = {
  Dumbbell: Dumbbell,
  Zap: Zap,
  Flame: Flame,
  Sparkles: Sparkles,
};

export default function Services() {
  const [selectedServiceId, setSelectedServiceId] = useState<string | null>(null);

  const activeService = SERVICES.find((s) => s.id === selectedServiceId) || SERVICES[0];

  return (
    <section id="services" className="py-24 bg-[#09090b] border-t border-zinc-900 relative">
      
      {/* Visual Accent */}
      <div className="absolute top-[10%] right-[5%] w-96 h-96 bg-red-600/5 rounded-full blur-[100px] pointer-events-none" />
      <div className="absolute bottom-[10%] left-[5%] w-80 h-80 bg-red-600/5 rounded-full blur-[100px] pointer-events-none" />

      <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        {/* Section Header */}
        <div className="text-center max-w-3xl mx-auto mb-16 space-y-4">
          <div className="inline-flex items-center gap-1.5 px-3 py-1 bg-red-950/30 border border-red-900/40 rounded-full text-red-500 text-xs font-mono tracking-widest uppercase">
            ⚡ PROFESSIONAL LEVEL TRAINING
          </div>
          <h2 className="font-display text-3xl sm:text-5xl font-black text-white leading-tight">
            NOTHING MOCKED, <span className="text-red-500">REAL RESULTS</span>
          </h2>
          <p className="text-zinc-400 text-base">
            Site Cart provides the ultimate ecosystem for body sculpting, power progression, and vascular recovery. Explore our target divisions below.
          </p>
        </div>

        {/* Dynamic Master-Detail Layout */}
        <div className="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
          
          {/* Services Cards List (7 Cols) */}
          <div className="lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-4" id="services-cards-grid">
            {SERVICES.map((s) => {
              const IconComp = iconMap[s.iconName] || Dumbbell;
              const isSelected = selectedServiceId === s.id;

              return (
                <div
                  key={s.id}
                  onClick={() => setSelectedServiceId(s.id)}
                  className={`group relative p-6 bg-zinc-950 border rounded-xl cursor-pointer transition-all duration-300 hover:-translate-y-1 ${
                    isSelected
                      ? 'border-red-600 shadow-[0_0_25px_rgba(220,38,38,0.2)] bg-gradient-to-br from-zinc-950 via-zinc-950 to-red-950/30'
                      : 'border-zinc-800/80 hover:border-zinc-700 hover:bg-zinc-900/40'
                  }`}
                  id={`service-card-${s.id}`}
                >
                  {/* Decorative glow corner */}
                  {isSelected && (
                    <div className="absolute top-0 right-0 w-8 h-8 bg-red-600 rounded-bl-3xl blur-md opacity-45" />
                  )}

                  <div className="flex items-center justify-between mb-4">
                    <div className={`p-3 rounded-lg ${isSelected ? 'bg-red-600 text-white' : 'bg-zinc-900 text-zinc-400 group-hover:text-red-500 group-hover:bg-zinc-800'} transition-all duration-300`}>
                      <IconComp className="w-6 h-6" />
                    </div>
                    <ChevronRight className={`w-4 h-4 transition-transform duration-300 ${isSelected ? 'transform rotate-90 text-red-500' : 'text-zinc-600'}`} />
                  </div>

                  <h3 className={`font-display text-lg font-bold ${isSelected ? 'text-white' : 'text-zinc-200 group-hover:text-red-400'} transition-all duration-200`}>
                    {s.title}
                  </h3>

                  <p className="text-zinc-400 text-xs leading-relaxed mt-2 long-text-trim">
                    {s.description}
                  </p>

                  <div className="mt-4 pt-4 border-t border-zinc-905 flex justify-between items-center text-[10px] font-mono tracking-widest uppercase">
                    <span className={isSelected ? 'text-red-400 font-extrabold' : 'text-zinc-500'}>READ DETAILS</span>
                    <span className="text-zinc-600">Site Cart Gym</span>
                  </div>
                </div>
              );
            })}
          </div>

          {/* Interactive Detailed Spotlight Showcase (5 Cols) */}
          <div className="lg:col-span-5" id="services-spotlight">
            <div className="bg-zinc-950 border border-zinc-850 rounded-2xl overflow-hidden shadow-2xl relative sticky top-24">
              
              {/* Service Img */}
              <div className="h-48 relative overflow-hidden">
                <img
                  src={activeService.imageUrl}
                  alt={activeService.title}
                  className="w-full h-full object-cover filter brightness-[0.4] saturate-125 hover:scale-105 transition-transform duration-500"
                  referrerPolicy="no-referrer"
                />
                
                {/* Visual Badges */}
                <span className="absolute top-4 left-4 bg-red-600 text-white font-mono text-[9px] font-bold px-3 py-1 rounded-full uppercase tracking-wider">
                  Spotlight Specialty
                </span>
                
                <div className="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/20 to-transparent" />
              </div>

              {/* Service Details Body */}
              <div className="p-6 sm:p-8 space-y-4">
                
                <div className="flex items-center gap-2">
                  <div className="p-2 bg-red-950 text-red-500 border border-red-500/30 rounded-lg">
                    {React.createElement(iconMap[activeService.iconName] || Dumbbell, { className: 'w-5 h-5' })}
                  </div>
                  <h4 className="font-display text-xl sm:text-2xl font-extrabold text-white">
                    {activeService.title}
                  </h4>
                </div>

                <p className="text-zinc-300 text-sm leading-relaxed" id="service-long-desc">
                  {activeService.longDescription}
                </p>

                {/* Additional Technical Attributes (Enhancing aesthetic realness) */}
                <div className="bg-zinc-900 border border-zinc-850 rounded-xl p-4 space-y-3 font-display">
                  <span className="text-[10px] font-mono tracking-widest text-zinc-500 uppercase block">SITE CART METRICS</span>
                  <div className="grid grid-cols-2 gap-4">
                    <div>
                      <span className="text-zinc-500 text-[10px] block font-mono uppercase">Avg Progress Spike</span>
                      <span className="text-base text-white font-black">+42% Muscle Output</span>
                    </div>
                    <div>
                      <span className="text-zinc-500 text-[10px] block font-mono uppercase">Trainer Ratio</span>
                      <span className="text-base text-white font-black">1:1 Precision Guided</span>
                    </div>
                    <div>
                      <span className="text-zinc-500 text-[10px] block font-mono uppercase">Included Steam Session</span>
                      <span className="text-base text-red-500 font-extrabold">Unlimited access</span>
                    </div>
                    <div>
                      <span className="text-zinc-500 text-[10px] block font-mono uppercase">Recommended Freq</span>
                      <span className="text-base text-white font-black">3 - 4 Days/week</span>
                    </div>
                  </div>
                </div>

                {/* Enquiry CTA targeted to this service */}
                <div className="pt-2">
                  <a
                    href={GYM_CONTACT.whatsappUrl(`Hi Site Cart Gym, I want to join the "${activeService.title}" program and book a free introductory walk-through.`)}
                    target="_blank"
                    rel="noopener noreferrer"
                    className="w-full py-3.5 bg-red-600 hover:bg-red-700 text-white font-bold text-center rounded-lg uppercase tracking-wider text-xs flex items-center justify-center gap-2 transition-colors duration-300"
                    id={`enquire-${activeService.id}`}
                  >
                     ⚡ Enquire About {activeService.title}
                  </a>
                </div>

              </div>

            </div>
          </div>

        </div>

      </div>
    </section>
  );
}
